{:paths ["src" "resources"]

 :deps {org.clojure/clojure {:mvn/version "1.12.1"}
        com.taoensso/timbre {:mvn/version "6.8.0"}

        ;; hive-dsl — Result ADT, rescue/guard DSL
        io.github.hive-agi/hive-dsl
        {:mvn/version "0.5.7"}

        ;; Subprocess for headed agent CLIs
        babashka/process {:mvn/version "0.6.25"}}

 :aliases
 {
  ;; :build — tools.build entrypoint (clojure -T:build <task>). Canonical hive
  ;; build: jar / jar-aot / install / bump / verify-license / deploy.
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.9"}
                 slipset/deps-deploy {:mvn/version "0.2.2"}}
          :ns-default build}
:test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                org.clojure/test.check {:mvn/version "1.1.1"}}
   :main-opts ["-m" "cognitect.test-runner"]}}}
