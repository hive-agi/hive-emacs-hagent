(ns hive-hagent-backend-openclaude
  "openclaude CLI backend adapter.

   Spawns the `openclaude' binary inside a vterm (or eat) buffer so the
   user interacts with the full TUI exactly as they would on the shell.
   We control only session lifecycle + keystroke injection — no stream
   parsing, no output capture.

   Modelled on claude-code-ide.el's terminal spawning logic, trimmed to
   the minimum hive-hagent needs."
  (:require hive-hagent-backend
            hive-hagent-log))

;; External declarations (vterm / eat are optional runtime deps)
(declare-function vterm "vterm" (&optional arg))
(declare-function vterm-send-string "vterm" (string &optional paste-p))
(declare-function vterm-send-return "vterm" ())
(declare-function vterm-send-escape "vterm" ())
(defvar vterm-buffer-name)
(defvar vterm-shell)
(defvar vterm-environment)

(declare-function eat-mode "eat" ())
(declare-function eat-exec "eat" (buffer name command startfile switches))
(declare-function eat-term-send-string "eat" (terminal string))
(defvar eat-terminal)
(defvar eat-term-name)

;; ---------------------------------------------------------------------------
;; Configuration
;; ---------------------------------------------------------------------------

(defcustom hive-hagent-openclaude-cli-path "openclaude"
  "Path to the openclaude CLI binary."
  :type 'string
  :group 'hive-hagent)

(defcustom hive-hagent-openclaude-extra-flags ""
  "Extra flags appended to every openclaude invocation."
  :type 'string
  :group 'hive-hagent)

;; ---------------------------------------------------------------------------
;; Command building
;; ---------------------------------------------------------------------------

(defn -build-command []
  "Return the openclaude shell command string."
  (let [base hive-hagent-openclaude-cli-path
        flags hive-hagent-openclaude-extra-flags]
    (if (and flags (not (string-empty-p flags)))
      (concat base " " flags)
      base)))

;; ---------------------------------------------------------------------------
;; Spawn
;; ---------------------------------------------------------------------------

(defn -spawn-vterm [buf-name cmd project-root]
  "Spawn CMD in a new vterm buffer named BUF-NAME, rooted at PROJECT-ROOT."
  (unless (require 'vterm nil t)
    (error "vterm not available; install vterm or switch hive-hagent-terminal-backend"))
  (let [default-directory (or project-root default-directory)
        vterm-buffer-name buf-name
        vterm-shell cmd
        vterm-environment (append (list "TERM_PROGRAM=emacs") vterm-environment)
        buf (save-window-excursion (vterm vterm-buffer-name))]
    (unless buf
      (error "Failed to create vterm buffer for openclaude"))
    (let [proc (get-buffer-process buf)]
      (unless proc
        (error "vterm did not produce a live process"))
      (list :buffer buf :process proc))))

(defn -spawn-eat [buf-name cmd project-root]
  "Spawn CMD in an eat buffer named BUF-NAME, rooted at PROJECT-ROOT."
  (unless (require 'eat nil t)
    (error "eat not available; install eat or switch hive-hagent-terminal-backend"))
  (let [default-directory (or project-root default-directory)
        buf (get-buffer-create buf-name)
        eat-term-name "xterm-256color"
        parts (split-string cmd " " t)
        program (car parts)
        args (cdr parts)]
    (with-current-buffer buf
      (unless (eq major-mode 'eat-mode)
        (eat-mode))
      (eat-exec buf buf-name program nil args)
      (let [proc (get-buffer-process buf)]
        (unless proc
          (error "eat did not produce a live process"))
        (list :buffer buf :process proc)))))

(defn start-fn [opts]
  "IChatBackend :start-fn entry point."
  (let [root (plist-get opts :project-root)
        buf-name (plist-get opts :buffer-name)
        term (or (plist-get opts :terminal) 'vterm)
        cmd (hive-hagent-backend-openclaude/-build-command)]
    (hive-hagent-log/log-info 'openclaude "spawning %s in %s (%s)"
                              cmd (or root "<global>") term)
    (pcase term
      ('vterm (hive-hagent-backend-openclaude/-spawn-vterm buf-name cmd root))
      ('eat   (hive-hagent-backend-openclaude/-spawn-eat   buf-name cmd root))
      (_ (error "Unknown terminal backend: %S" term)))))

;; ---------------------------------------------------------------------------
;; Keystroke injection
;; ---------------------------------------------------------------------------

(defn -with-buffer [handle body-fn]
  "Run BODY-FN in HANDLE's buffer, if live."
  (let [buf (plist-get handle :buffer)]
    (when (and buf (buffer-live-p buf))
      (with-current-buffer buf
        (funcall body-fn)))))

(defn send-fn [handle prompt]
  "IChatBackend :send-fn — paste PROMPT into the TUI and press return."
  (hive-hagent-backend-openclaude/-with-buffer
   handle
   (lambda []
     (cond
      ((derived-mode-p 'vterm-mode)
       (vterm-send-string prompt t)
       (vterm-send-return))
      ((derived-mode-p 'eat-mode)
       (eat-term-send-string eat-terminal prompt)
       (eat-term-send-string eat-terminal "\r"))
      (t
       (hive-hagent-log/log-warn
        'openclaude "unknown terminal mode in buffer: %S" major-mode))))))

(defn interrupt-fn [handle]
  "IChatBackend :interrupt-fn — send ESC to cancel current turn."
  (hive-hagent-backend-openclaude/-with-buffer
   handle
   (lambda []
     (cond
      ((derived-mode-p 'vterm-mode) (vterm-send-escape))
      ((derived-mode-p 'eat-mode)   (eat-term-send-string eat-terminal "\e"))
      (t nil)))))

(defn stop-fn [handle]
  "IChatBackend :stop-fn — kill process + buffer."
  (let [proc (plist-get handle :process)
        buf  (plist-get handle :buffer)]
    (when (and proc (process-live-p proc))
      (delete-process proc))
    (when (and buf (buffer-live-p buf))
      (kill-buffer buf))))

;; ---------------------------------------------------------------------------
;; Registration
;; ---------------------------------------------------------------------------

(defvar hive-hagent-backend-openclaude--backend
  ;; Quoted symbols pass through the cljel compiler verbatim — reference
  ;; the compiled elisp names directly so `funcall' resolves at runtime.
  (list :name 'openclaude
        :label "openclaude"
        :start-fn 'hive-hagent-backend-openclaude-start-fn
        :send-fn 'hive-hagent-backend-openclaude-send-fn
        :interrupt-fn 'hive-hagent-backend-openclaude-interrupt-fn
        :stop-fn 'hive-hagent-backend-openclaude-stop-fn)
  "The openclaude backend plist.")

;; Register on load
(hive-hagent-backend/register! hive-hagent-backend-openclaude--backend)

(provide 'hive-hagent-backend-openclaude)
