(ns hive-hagent-backend
  "IChatBackend protocol — plist-based dispatch.

   A backend is a plist with keys:
     :name      symbol identifying the backend (e.g. 'openclaude, 'agent)
     :label     human-readable label for UI
     :start-fn  (session-opts) -> session-handle (opaque map)
     :send-fn   (handle prompt) -> nil    (enqueue user turn)
     :interrupt-fn (handle)     -> nil    (cancel in-flight turn)
     :stop-fn   (handle)        -> nil    (terminate subprocess + cleanup)
     :alive-p-fn (handle)       -> bool   (session still running?)

   The returned session handle is a plist the backend owns; the core
   never introspects it, only passes it back to the backend fns.

   Why plists not defprotocol: cljel emits plain elisp — no CLOS/protocols.
   Keyword dispatch is the idiomatic elisp analogue.")

(defvar hive-hagent-backend--registry nil
  "Alist of (backend-name . backend-plist) for all registered backends.")

(defn register! [backend]
  "Register BACKEND plist.  Overwrites any existing entry with the same :name."
  (let [name (plist-get backend :name)]
    (setq hive-hagent-backend--registry
          (cons (cons name backend)
                (assq-delete-all name hive-hagent-backend--registry)))
    name))

(defn get-backend [name]
  "Look up backend by NAME symbol.  Returns plist or nil."
  (cdr (assq name hive-hagent-backend--registry)))

(defn list-backends []
  "Return list of all registered backend names."
  (mapcar 'car hive-hagent-backend--registry))

;; ---------------------------------------------------------------------------
;; Dispatch helpers — thin funcall wrappers so the core doesn't care
;; which backend it's talking to.
;; ---------------------------------------------------------------------------

(defn start [backend opts]
  "Start a session on BACKEND with OPTS.  Returns session handle."
  (funcall (plist-get backend :start-fn) opts))

(defn send [backend handle prompt]
  "Send PROMPT to BACKEND session HANDLE."
  (funcall (plist-get backend :send-fn) handle prompt))

(defn interrupt [backend handle]
  "Interrupt the current turn on BACKEND session HANDLE."
  (funcall (plist-get backend :interrupt-fn) handle))

(defn stop [backend handle]
  "Stop and tear down BACKEND session HANDLE."
  (funcall (plist-get backend :stop-fn) handle))

(defn alive-p [backend handle]
  "Non-nil if BACKEND session HANDLE is still alive."
  (funcall (plist-get backend :alive-p-fn) handle))

(provide 'hive-hagent-backend)
