(ns hive-hagent
  "Top-level entry point for hive-emacs-hagent.

   Loads the core + all registered backends and exposes the
   user-facing commands: `hive-hagent', `hive-hagent-send',
   `hive-hagent-interrupt', `hive-hagent-stop',
   `hive-hagent-switch-backend', `hive-hagent-list-sessions'.

   Usage:
     (require 'hive-hagent)
     (global-set-key (kbd \"C-c h a\") #'hive-hagent)"
  (:require hive-hagent-log
            hive-hagent-backend
            hive-hagent-core
            hive-hagent-backend-openclaude
            hive-hagent-olympus))

;; ---------------------------------------------------------------------------
;; User-facing configuration
;; ---------------------------------------------------------------------------

(defcustom hive-hagent-default-backend 'openclaude
  "Backend used by `hive-hagent' when no per-project override exists."
  :type '(choice (const openclaude) (const agent))
  :group 'hive-hagent)

(defvar hive-hagent--project-backends nil
  "Alist of (project-root . backend-name) overrides.")

(defn -resolve-backend-name []
  "Return the backend symbol to use for the current project."
  (let [root (hive-hagent-core/-current-project-root)
        override (cdr (assoc root hive-hagent--project-backends))]
    (or override hive-hagent-default-backend)))

(defn -resolve-backend []
  "Return the active backend plist for the current project."
  (let [name (hive-hagent/-resolve-backend-name)
        backend (hive-hagent-backend/get-backend name)]
    (unless backend
      (error "No hive-hagent backend registered under name %S" name))
    backend))

(defn -current-session []
  "Return the live session for the current project + active backend, or nil."
  (let [root (hive-hagent-core/-current-project-root)
        name (hive-hagent/-resolve-backend-name)]
    (hive-hagent-core/find-session root name)))

;; ---------------------------------------------------------------------------
;; Interactive commands
;; ---------------------------------------------------------------------------

;; Interactive-command defns: names intentionally DO NOT repeat the `hive-hagent'
;; namespace prefix — the cljel compiler prepends it, so e.g. (defn chat [] ...)
;; becomes (defun hive-hagent-chat () ...).  Double-prefixing would break
;; `M-x hive-hagent-chat'.

(defn chat []
  "Open (or reuse) a hagent chat for the current project."
  (interactive)
  (hive-hagent-core/open-session (hive-hagent/-resolve-backend)))

(defn send [prompt]
  "Send PROMPT to the active hagent session for this project.
Starts a session if none exists."
  (interactive "sPrompt: ")
  (let [session (or (hive-hagent/-current-session)
                    (hive-hagent-core/open-session
                     (hive-hagent/-resolve-backend)))]
    (hive-hagent-core/send-prompt session prompt)))

(defn send-region [beg end]
  "Send the region BEG..END as a prompt."
  (interactive "r")
  (hive-hagent/send (buffer-substring-no-properties beg end)))

(defn interrupt []
  "Interrupt the current turn in the active hagent session."
  (interactive)
  (let [session (hive-hagent/-current-session)]
    (if session
      (hive-hagent-core/interrupt-session session)
      (message "hive-hagent: no active session"))))

(defn stop []
  "Stop and tear down the hagent session for this project."
  (interactive)
  (let [session (hive-hagent/-current-session)]
    (if session
      (hive-hagent-core/stop-session session)
      (message "hive-hagent: no active session"))))

(defn switch-backend []
  "Pick a backend for the current project, remembered for this session."
  (interactive)
  (let [names (mapcar 'symbol-name (hive-hagent-backend/list-backends))
        choice (completing-read "hive-hagent backend: " names nil t)
        sym (intern choice)
        root (hive-hagent-core/-current-project-root)]
    (setq hive-hagent--project-backends
          (cons (cons root sym)
                (assoc-delete-all root hive-hagent--project-backends)))
    (message "hive-hagent: %s active in %s" sym (or root "<global>"))))

(defn list-sessions []
  "Show all live hagent sessions in the echo area."
  (interactive)
  (let [sessions (hive-hagent-core/active-sessions)]
    (if (null sessions)
      (message "hive-hagent: no active sessions")
      (message "hive-hagent: %d active session(s): %s"
               (length sessions)
               (mapconcat
                (lambda [s]
                  (format "%s/%s"
                          (plist-get (plist-get s :backend) :name)
                          (or (plist-get s :project-root) "<global>")))
                sessions
                ", ")))))

;; ---------------------------------------------------------------------------
;; Keymap + minor mode
;;
;; Native elisp pattern (mirrors hive-mcp-triggers):
;;   - command-map   holds the sub-keys under the user prefix
;;   - prefix var    is a defcustom so users pick their own prefix
;;   - minor mode    binds the prefix to the command map when enabled
;;
;; Doom/evil users can bind the minor-mode map via `map!' in their own
;; config, or simply set `hive-hagent-keymap-prefix' and flip the mode on.
;; ---------------------------------------------------------------------------

(defcustom hive-hagent-keymap-prefix nil
  "Prefix key for `hive-hagent' commands.
Set this in your init file before enabling `hive-hagent-mode'.
Example: (setq hive-hagent-keymap-prefix (kbd \"C-c h\"))
Note: Control-c <letter> is reserved for user bindings per Emacs
conventions, which is exactly what this prefix is meant to be."
  :type '(choice (const :tag "None" nil) key-sequence)
  :group 'hive-hagent)

(defvar hive-hagent-command-map
  (let [map (make-sparse-keymap)]
    (define-key map (kbd "h") 'hive-hagent/chat)
    (define-key map (kbd "s") 'hive-hagent/send)
    (define-key map (kbd "r") 'hive-hagent/send-region)
    (define-key map (kbd "i") 'hive-hagent/interrupt)
    (define-key map (kbd "q") 'hive-hagent/stop)
    (define-key map (kbd "b") 'hive-hagent/switch-backend)
    (define-key map (kbd "l") 'hive-hagent/list-sessions)
    map)
  "Keymap for `hive-hagent' commands, bound under `hive-hagent-keymap-prefix'.")

(defvar hive-hagent-mode-map (make-sparse-keymap)
  "Keymap for `hive-hagent-mode'.")

(defn setup-keybindings []
  "Install `hive-hagent-command-map' under `hive-hagent-keymap-prefix'.
No-op if the prefix is unset."
  (when hive-hagent-keymap-prefix
    (define-key hive-hagent-mode-map
                hive-hagent-keymap-prefix
                hive-hagent-command-map)))

;; define-minor-mode isn't supported by cljel yet; expand the handful of
;; forms we need directly.  Public state var shares the `hive-hagent-mode'
;; symbol (required by minor-mode conventions); the toggle fn is named
;; `mode' and compiles to `hive-hagent-mode', shadowing the defvar as a
;; function cell — elisp allows both on the same symbol.
(defvar hive-hagent-mode nil
  "Non-nil when `hive-hagent-mode' is enabled globally.")

(defn mode [&optional arg]
  "Toggle `hive-hagent-mode'.
With positive ARG enable, with non-positive ARG disable, otherwise toggle."
  (interactive "P")
  (let [enable (cond ((null arg) (not hive-hagent-mode))
                     ((and (numberp arg) (> arg 0)) t)
                     (t nil))]
    (setq hive-hagent-mode enable)
    (if enable
      (progn
        (hive-hagent/setup-keybindings)
        (message "hive-hagent-mode enabled"))
      (message "hive-hagent-mode disabled"))))

(provide 'hive-hagent)
